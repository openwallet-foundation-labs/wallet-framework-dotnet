<?xml version="1.0"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <id>WalletFramework.Main</id>
        <version>$version$</version>
        <title>Wallet Framework for .NET Main</title>
        <authors>Wallet Framework .NET Maintainers</authors>
        <owners>Wallet Framework .NET Maintainers</owners>
        <requireLicenseAcceptance>false</requireLicenseAcceptance>
        <description>Main Wallet Framework package for .NET. This package bundles all the core Wallet Framework components.</description>
        <projectUrl>https://github.com/openwallet-foundation-labs/wallet-framework-dotnet</projectUrl>
        <repository url="https://github.com/openwallet-foundation-labs/wallet-framework-dotnet.git" type="git" />
        <license type="expression">Apache-2.0</license>
        <tags>Wallet Framework for .NET</tags>
        <dependencies>
            <group targetFramework="net8.0">
                <!-- Core dependencies -->
                <dependency id="jose-jwt" version="5.0.0" />
                <dependency id="LanguageExt.Core" version="4.4.9" />
                <dependency id="Microsoft.Extensions.Http" version="3.1.5" />
                <dependency id="Microsoft.IdentityModel.Tokens" version="8.0.1" />
                <dependency id="Newtonsoft.Json" version="13.0.3" />
                <dependency id="OneOf" version="3.0.271" />
                <dependency id="Portable.BouncyCastle" version="1.9.0" />
                <dependency id="System.IdentityModel.Tokens.Jwt" version="7.5.2" />
                <dependency id="System.Reactive" version="6.0.1" />
                <!-- Storage dependencies -->
                <dependency id="Microsoft.EntityFrameworkCore.Sqlite.Core" version="9.0.8" />
                <!-- MdocLib dependencies -->
                <dependency id="PeterO.Cbor" version="4.5.3" />
            </group>
        </dependencies>
    </metadata>
    <files>
        <!-- Core assembly -->
        <file src="src\WalletFramework.Core\bin\Release\net8.0\WalletFramework.Core.dll" target="lib\net8.0" />
        <file src="src\WalletFramework.Core\bin\Release\net8.0\WalletFramework.Core.pdb" target="lib\net8.0" />
        
        <!-- Storage assembly -->
        <file src="src\WalletFramework.Storage\bin\Release\net8.0\WalletFramework.Storage.dll" target="lib\net8.0" />
        <file src="src\WalletFramework.Storage\bin\Release\net8.0\WalletFramework.Storage.pdb" target="lib\net8.0" />
        
        <!-- SdJwtLib assembly -->
        <file src="src\WalletFramework.SdJwtLib\bin\Release\net8.0\WalletFramework.SdJwtLib.dll" target="lib\net8.0" />
        <file src="src\WalletFramework.SdJwtLib\bin\Release\net8.0\WalletFramework.SdJwtLib.pdb" target="lib\net8.0" />
        
        <!-- MdocLib assembly -->
        <file src="src\WalletFramework.MdocLib\bin\Release\net8.0\WalletFramework.MdocLib.dll" target="lib\net8.0" />
        <file src="src\WalletFramework.MdocLib\bin\Release\net8.0\WalletFramework.MdocLib.pdb" target="lib\net8.0" />
        
        <!-- SdJwtVc assembly -->
        <file src="src\WalletFramework.SdJwtVc\bin\Release\net8.0\WalletFramework.SdJwtVc.dll" target="lib\net8.0" />
        <file src="src\WalletFramework.SdJwtVc\bin\Release\net8.0\WalletFramework.SdJwtVc.pdb" target="lib\net8.0" />
        
        <!-- MdocVc assembly -->
        <file src="src\WalletFramework.MdocVc\bin\Release\net8.0\WalletFramework.MdocVc.dll" target="lib\net8.0" />
        <file src="src\WalletFramework.MdocVc\bin\Release\net8.0\WalletFramework.MdocVc.pdb" target="lib\net8.0" />
        
        <!-- Oid4Vc assembly -->
        <file src="src\WalletFramework.Oid4Vc\bin\Release\net8.0\WalletFramework.Oid4Vc.dll" target="lib\net8.0" />
        <file src="src\WalletFramework.Oid4Vc\bin\Release\net8.0\WalletFramework.Oid4Vc.pdb" target="lib\net8.0" />
    </files>
</package>
